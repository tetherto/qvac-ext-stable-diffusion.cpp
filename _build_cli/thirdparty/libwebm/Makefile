#=============================================================================
# Special targets to cleanup operation of make.

# Special rule to run CMake to check the build system integrity.
# No rule that depends on this can have commands that come from listfiles
# because they might be regenerated.
cmake_check_build_system:
	cd /Users/user030/Documents/qvac-ext-stable-diffusion.cpp/_build_cli && $(CMAKE_COMMAND) -P /Users/user030/Documents/qvac-ext-stable-diffusion.cpp/_build_cli/CMakeFiles/VerifyGlobs.cmake
	cd /Users/user030/Documents/qvac-ext-stable-diffusion.cpp/_build_cli && $(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles/Makefile.cmake 0
.PHONY : cmake_check_build_system

